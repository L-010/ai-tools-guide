---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { buildSeo, type SeoProps } from "@/utils/seo";
import "@/styles/global.css";

type Props = SeoProps & { schema?: unknown };
const seo = buildSeo(Astro.props);
const schema = Astro.props.schema;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />
    <link rel="alternate" hreflang="zh-CN" href={seo.canonical} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:type" content={seo.type} />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:image" content={seo.ogImage} />
    <meta property="og:locale" content={seo.locale} />
    <meta property="og:site_name" content={seo.siteName} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={seo.ogImage} />
    <meta name="google-site-verification" content="P2diHTMKVfm8NFJiCme4ZSzmsXsfpoboWgEF3_0MY9k" />
    <meta name="baidu-site-verification" content="codeva-8jwIHWtigv" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      document.addEventListener("click", (event) => {
        const target = event.target instanceof Element ? event.target.closest("[data-shop-cta]") : null;
        if (!target) return;
        const payload = {
          page_slug: target.getAttribute("data-page-slug") || "",
          cta_position: target.getAttribute("data-cta-position") || "",
          cta_text: target.textContent?.trim() || "",
          destination_url: target.getAttribute("href") || ""
        };
        window.dataLayer?.push({ event: "shop_cta_click", ...payload });
        window.aiToolsGuideTrack?.("shop_cta_click", payload);
      });
    </script>
  </body>
</html>

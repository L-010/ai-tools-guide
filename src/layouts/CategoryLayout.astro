---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import CategoryNextReading from "@/components/CategoryNextReading.astro";
import CTABox from "@/components/CTABox.astro";
import { categoryPages, getCategoryTopRelatedPosts, rankCategoryPosts, type CategorySlug } from "@/data/categories";
import { absoluteUrl } from "@/utils/urls";
import { breadcrumbSchema } from "@/utils/schema";

type Props = { categorySlug: CategorySlug };
const { categorySlug } = Astro.props;
const category = categoryPages[categorySlug];
const allPosts = await getCollection("posts");
const rankedPosts = rankCategoryPosts(allPosts, categorySlug);
const topRelatedPosts = getCategoryTopRelatedPosts(allPosts, categorySlug);
const pathname = `/${category.slug}/`;
const crumbs = [
  { name: "首页", url: absoluteUrl("/") },
  { name: category.shortTitle, url: absoluteUrl(pathname) }
];
---
<BaseLayout
  title={`${category.title}｜按用途、差异和场景选择 AI 工具`}
  description={category.description}
  pathname={pathname}
  schema={breadcrumbSchema(crumbs)}
>
  <section class="mx-auto max-w-6xl px-5 py-10 md:py-14">
    <Breadcrumbs items={crumbs} />
    <div class="max-w-3xl">
      <p class="text-sm font-bold uppercase tracking-wide text-brand">AI tools guide</p>
      <h1 class="mt-3 text-4xl font-bold leading-tight text-ink md:text-5xl">{category.title}</h1>
      <p class="mt-5 text-lg leading-8 text-muted">{category.description}</p>
      <p class="mt-3 leading-7 text-muted">{category.hero}</p>
      <div class="mt-6 grid gap-3 sm:flex sm:flex-wrap">
        <a class="inline-flex min-h-11 items-center justify-center rounded-md bg-brand px-5 py-3 text-sm font-semibold text-white no-underline hover:bg-teal-800" href="#category-next-reading">先读精选指南</a>
        <a class="inline-flex min-h-11 items-center justify-center rounded-md border border-line bg-white px-5 py-3 text-sm font-semibold text-ink no-underline hover:bg-slate-50" href="#category-articles">查看全部文章</a>
        <a class="inline-flex min-h-11 items-center justify-center px-2 py-3 text-sm font-semibold no-underline" href="/">返回首页</a>
      </div>
    </div>

    <CategoryNextReading posts={topRelatedPosts} categoryName={category.shortTitle} />

    <section id="category-articles" class="mt-12 scroll-mt-6" aria-labelledby="category-articles-title">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <h2 id="category-articles-title" class="text-3xl font-bold text-ink">全部{category.shortTitle}文章</h2>
          <p class="mt-2 text-sm leading-6 text-muted">默认按推荐指数排序；“站内热度”根据相关文章的 relatedSlugs 推荐次数计算，不代表真实阅读量。</p>
        </div>
        <div class="flex flex-wrap gap-2" role="group" aria-label="文章排序方式">
          <button type="button" class="category-sort-button min-h-11 rounded-md bg-ink px-4 py-2 text-sm font-semibold text-white" data-sort-mode="recommended" aria-pressed="true">推荐优先</button>
          <button type="button" class="category-sort-button min-h-11 rounded-md border border-line bg-white px-4 py-2 text-sm font-semibold text-ink" data-sort-mode="heat" aria-pressed="false">站内热度</button>
          <button type="button" class="category-sort-button min-h-11 rounded-md border border-line bg-white px-4 py-2 text-sm font-semibold text-ink" data-sort-mode="latest" aria-pressed="false">最近更新</button>
        </div>
      </div>

      <p id="category-sort-status" class="sr-only" aria-live="polite">当前按推荐优先排序</p>
      <div id="category-article-grid" class="mt-6 grid gap-5 sm:grid-cols-2">
        {rankedPosts.map(({ post, recommendationScore, heatScore, dateScore }) => (
          <div
            class="min-w-0"
            data-category-card
            data-recommendation-score={recommendationScore}
            data-heat-score={heatScore}
            data-date-score={dateScore}
            data-title={post.data.title}
          >
            <ArticleCard post={post} />
          </div>
        ))}
      </div>
    </section>

    <div class="mt-8 flex justify-center">
      <a class="inline-flex min-h-11 items-center justify-center rounded-md border border-line bg-white px-5 py-3 text-sm font-semibold text-ink no-underline hover:bg-slate-50" href="/">返回首页查看其他分类</a>
    </div>

    <CTABox
      pageSlug={category.slug}
      position="bottom"
      title="已经明确主要用途？"
      description="可以先阅读最接近需求的文章，再进入小店查看当前可选分类。"
      buttonText="直接查看小店分类"
    />
  </section>
  <script is:inline>
    (() => {
      const grid = document.getElementById("category-article-grid");
      const buttons = Array.from(document.querySelectorAll("[data-sort-mode]"));
      const status = document.getElementById("category-sort-status");
      if (!grid || buttons.length === 0) return;

      const sortCards = (mode) => {
        const cards = Array.from(grid.querySelectorAll("[data-category-card]"));
        const scoreAttribute = mode === "heat" ? "data-heat-score" : mode === "latest" ? "data-date-score" : "data-recommendation-score";
        cards.sort((a, b) => {
          const scoreDifference = Number(b.getAttribute(scoreAttribute) || 0) - Number(a.getAttribute(scoreAttribute) || 0);
          if (scoreDifference !== 0) return scoreDifference;
          return String(a.getAttribute("data-title") || "").localeCompare(String(b.getAttribute("data-title") || ""), "zh-CN");
        });
        cards.forEach((card) => grid.appendChild(card));
        buttons.forEach((button) => {
          const active = button.getAttribute("data-sort-mode") === mode;
          button.setAttribute("aria-pressed", String(active));
          button.classList.toggle("bg-ink", active);
          button.classList.toggle("text-white", active);
          button.classList.toggle("bg-white", !active);
          button.classList.toggle("text-ink", !active);
        });
        const label = mode === "heat" ? "站内热度" : mode === "latest" ? "最近更新" : "推荐优先";
        if (status) status.textContent = `当前按${label}排序`;
        window.dataLayer?.push({ event: "category_sort_change", category: location.pathname, sort_mode: mode });
      };

      buttons.forEach((button) => {
        button.addEventListener("click", () => sortCards(button.getAttribute("data-sort-mode") || "recommended"));
      });
    })();
  </script>
</BaseLayout>

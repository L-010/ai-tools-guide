---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import BuyButton from "@/components/BuyButton.astro";
import FAQ from "@/components/FAQ.astro";
import { categoryList, getFeaturedPosts } from "@/data/categories";
import { websiteSchema, faqSchema } from "@/utils/schema";

const title = "AI工具怎么选｜工具对比与场景方案";
const description = "按用途选择和对比 ChatGPT、Claude、Gemini、Cursor、Perplexity 等 AI 工具，查看论文、编程、办公场景方案与订阅建议。";
const featuredPosts = getFeaturedPosts(await getCollection("posts"), 8);
const heroVariants = [
  {
    id: "a",
    title: "按用途选择真正适合你的 AI 工具",
    description: "从工具选择、横向对比和具体场景出发，先判断需求，再决定使用哪款 AI 工具。"
  },
  {
    id: "b",
    title: "不知道 AI 工具怎么选？先看用途",
    description: "写论文、做办公、查资料或写代码，对应的工具不同。这里帮你快速找到判断路径。"
  },
  {
    id: "c",
    title: "先确定任务，再选择 AI 工具",
    description: "用清晰的选择、对比和场景指南，减少重复订阅，找到更贴近工作流的工具。"
  }
];
const faq = [
  { question: "第一次选择 AI 工具应该从哪里开始？", answer: "先进入工具选择分类，列出自己每周最常见的任务、使用频率和预算，再判断需要通用工具、搜索工具、写作工具还是编程工具。" },
  { question: "工具选择、工具对比和场景方案有什么区别？", answer: "工具选择帮助你确定方向，工具对比解释两个或多个工具的差异，场景方案则从论文、编程、办公等具体任务出发提供组合建议。" },
  { question: "本站会展示虚假价格、库存或评分吗？", answer: "不会。本站只提供选型、教程和购买前提醒，具体可选分类和方案以小店页面实际展示为准。" },
  { question: "是否必须购买多个 AI 工具？", answer: "不必。多数用户应先选择一个覆盖最高频任务的主力工具，确认稳定使用后，再决定是否补充搜索、长文或代码工具。" },
  { question: "购买入口会自动跳转吗？", answer: "不会。所有购买入口都需要用户主动点击，建议先完成用途判断，再进入小店查看当前分类。" }
];
---
<BaseLayout title={title} description={description} pathname="/" schema={[...websiteSchema(), faqSchema(faq)]}>
  <section class="border-b border-line bg-white">
    <div class="mx-auto max-w-6xl px-5 py-14 md:py-20">
      <p class="text-sm font-bold uppercase tracking-wide text-brand">AI tools guide</p>
      <h1 id="home-hero-title" class="mt-4 min-h-[5.5rem] max-w-4xl text-4xl font-bold leading-tight text-ink sm:min-h-0 md:text-6xl">{heroVariants[0].title}</h1>
      <p id="home-hero-description" class="mt-5 min-h-[5rem] max-w-3xl text-lg leading-8 text-muted sm:min-h-0">{heroVariants[0].description}</p>
      <div class="mt-7 grid gap-3 sm:flex sm:flex-wrap">
        <a data-home-entry="tool-selection" class="inline-flex min-h-11 items-center justify-center rounded-md bg-brand px-5 py-3 text-sm font-semibold text-white no-underline transition hover:bg-teal-800" href="/tool-selection/">按用途选工具</a>
        <a data-home-entry="tool-comparison" class="inline-flex min-h-11 items-center justify-center rounded-md border border-brand bg-white px-5 py-3 text-sm font-semibold text-brand no-underline transition hover:bg-teal-50" href="/tool-comparison/">对比两款工具</a>
        <a data-home-entry="scenario-guides" class="inline-flex min-h-11 items-center justify-center rounded-md border border-line bg-white px-5 py-3 text-sm font-semibold text-ink no-underline transition hover:bg-slate-50" href="/scenario-guides/">按场景看方案</a>
      </div>
    </div>
  </section>
  <script is:inline define:vars={{ heroVariants }}>
    (() => {
      const params = new URLSearchParams(window.location.search);
      const requested = params.get("hero_variant");
      const variantId = requested && heroVariants.some((item) => item.id === requested) ? requested : "a";
      const variant = heroVariants.find((item) => item.id === variantId) || heroVariants[0];
      const title = document.getElementById("home-hero-title");
      const description = document.getElementById("home-hero-description");
      if (variant.id !== "a") {
        if (title) title.textContent = variant.title;
        if (description) description.textContent = variant.description;
      }
      document.documentElement.dataset.heroVariant = variant.id;
      window.dataLayer?.push({ event: "home_hero_variant_view", variant_id: variant.id });

      document.addEventListener("click", (event) => {
        const link = event.target instanceof Element ? event.target.closest("[data-home-entry]") : null;
        if (!link) return;
        window.dataLayer?.push({
          event: "home_entry_click",
          variant_id: variant.id,
          entry: link.getAttribute("data-home-entry") || "",
          destination_url: link.getAttribute("href") || ""
        });
      });
    })();
  </script>

  <section class="mx-auto max-w-6xl px-5 py-12" aria-labelledby="main-categories">
    <h2 id="main-categories" class="text-3xl font-bold text-ink">三个主分类入口</h2>
    <p class="mt-3 text-muted">根据你当前的问题，选择最接近的一条路径。</p>
    <div class="mt-6 grid gap-5 md:grid-cols-3">
      {categoryList.map((category, index) => (
        <a class="rounded-xl border border-line bg-white p-6 no-underline shadow-sm transition hover:-translate-y-0.5 hover:shadow-md" href={`/${category.slug}/`}>
          <p class="text-sm font-bold text-brand">0{index + 1}</p>
          <h3 class="mt-3 text-2xl font-bold text-ink">{category.shortTitle}</h3>
          <p class="mt-3 text-sm leading-6 text-muted">{category.hero}</p>
          <span class="mt-5 inline-block text-sm font-semibold text-brand">进入分类</span>
        </a>
      ))}
    </div>
  </section>

  <section class="border-y border-line bg-slate-100/70">
    <div class="mx-auto max-w-6xl px-5 py-12">
      <h2 class="text-3xl font-bold text-ink">热门文章</h2>
      <p class="mt-3 text-muted">按最近更新与编辑推荐排序，从常见选型、工具对比和高频场景开始阅读。</p>
      <div class="mt-6 grid gap-5 md:grid-cols-2">
        {featuredPosts.map((post) => <ArticleCard post={post} />)}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-12">
    <div class="rounded-2xl bg-ink px-6 py-8 text-white md:flex md:items-center md:justify-between md:gap-8 md:px-10">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-bold">小店入口</h2>
        <p class="mt-3 leading-7 text-slate-200">已经明确用途和预算后，可以进入小店查看当前可选分类。本站不展示虚假价格、库存、评分或评论。</p>
      </div>
      <div class="mt-6 md:mt-0">
        <BuyButton pageSlug="home-shop" position="shop-section" text="直接查看小店分类" class="w-full bg-white text-ink hover:bg-slate-100 md:w-auto" />
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-10">
    <h2 class="text-3xl font-bold text-ink">信任说明</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-3">
      <article class="rounded-xl border border-line bg-white p-5">
        <h3 class="font-bold text-ink">内容与交易分离</h3>
        <p class="mt-2 text-sm leading-6 text-muted">本站负责选型教育和使用建议，小店负责展示当前可选方案与交易信息。</p>
      </article>
      <article class="rounded-xl border border-line bg-white p-5">
        <h3 class="font-bold text-ink">不制造虚假紧迫感</h3>
        <p class="mt-2 text-sm leading-6 text-muted">不展示虚假库存、倒计时、评分、评论或无法核实的价格承诺。</p>
      </article>
      <article class="rounded-xl border border-line bg-white p-5">
        <h3 class="font-bold text-ink">购买由用户主动决定</h3>
        <p class="mt-2 text-sm leading-6 text-muted">不自动跳转。所有小店入口均由用户主动点击，并明确标注为购买相关入口。</p>
      </article>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-10">
    <FAQ items={faq} />
  </section>
</BaseLayout>

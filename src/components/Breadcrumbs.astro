---
type Props = { items: { name: string; url: string }[] };
const { items } = Astro.props;
---
<nav aria-label="面包屑" class="mb-6 text-sm text-muted">
  <ol class="flex flex-wrap gap-2">
    {items.map((item, index) => (
      <li>
        {index > 0 && <span class="mr-2 text-slate-400">/</span>}
        {index === items.length - 1 ? <span>{item.name}</span> : <a href={new URL(item.url).pathname}>{item.name}</a>}
      </li>
    ))}
  </ol>
</nav>

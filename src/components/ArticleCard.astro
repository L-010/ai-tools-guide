---
import type { PostEntry } from "@/data/categories";
import { getPostDate, getPostExcerpt, getPostTags } from "@/data/categories";

type Props = { post: PostEntry };
const { post } = Astro.props;
const date = getPostDate(post);
const tags = getPostTags(post);
---
<article class="flex h-full min-w-0 flex-col rounded-xl border border-line bg-white p-5 shadow-sm">
  <div class="flex flex-wrap items-center gap-2 text-xs text-muted">
    <time datetime={date}>{date}</time>
    <span>·</span>
    <span>{post.data.category}</span>
  </div>
  <h2 class="mt-3 text-xl font-bold leading-snug text-ink">
    <a class="text-ink no-underline hover:text-brand" href={`/${post.slug}/`}>{post.data.title}</a>
  </h2>
  <p class="mt-3 line-clamp-3 text-sm leading-6 text-muted">{getPostExcerpt(post)}</p>
  {tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {tags.map((tag) => <span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-600">{tag}</span>)}
    </div>
  )}
  <a class="mt-auto inline-flex min-h-11 items-center pt-3 text-sm font-semibold" href={`/${post.slug}/`}>阅读全文</a>
</article>

---
import { SITE } from "@/data/site";
const nav = [
  { href: "/tool-selection/", label: "工具选择" },
  { href: "/tool-comparison/", label: "工具对比" },
  { href: "/scenario-guides/", label: "场景方案" },
  { href: "/shop/", label: "购买入口" }
];
---
<header class="border-b border-line bg-white/95">
  <div class="mx-auto flex max-w-6xl flex-col items-stretch gap-2 px-5 py-3 sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:py-4">
    <a class="inline-flex min-h-11 items-center text-lg font-bold text-ink no-underline" href="/">{SITE.shortName}</a>
    <nav aria-label="主导航" class="-mx-2 flex gap-1 overflow-x-auto px-2 pb-1 text-sm sm:mx-0 sm:flex-wrap sm:gap-2 sm:overflow-visible sm:px-0 sm:pb-0">
      {nav.map((item) => <a class="inline-flex min-h-11 shrink-0 items-center rounded-full px-3 py-2 text-muted no-underline hover:bg-slate-100 hover:text-ink" href={item.href}>{item.label}</a>)}
    </nav>
  </div>
</header>

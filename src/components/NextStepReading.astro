---
import BuyButton from "@/components/BuyButton.astro";
import type { PostEntry } from "@/data/categories";
import { getPostExcerpt } from "@/data/categories";

type Props = {
  posts: PostEntry[];
  pageSlug: string;
  buttonText: string;
  shopHref?: string;
  shopCategory?: string;
};

const { posts, pageSlug, buttonText, shopHref, shopCategory } = Astro.props;
---
<section class="mt-10 rounded-2xl border border-line bg-white p-5 md:p-6">
  <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
    <div>
      <h2 class="text-2xl font-bold text-ink">下一步阅读</h2>
      <p class="mt-2 text-sm leading-6 text-muted">继续从同类文章、相关对比和购买前提醒里确认方向，不急着下单。</p>
    </div>
    <BuyButton pageSlug={pageSlug} position="next-step" text={buttonText} class="w-full md:w-auto" shopHref={shopHref} shopCategory={shopCategory} />
  </div>
  <div class="mt-5 grid gap-4 md:grid-cols-3">
    {posts.map((post) => (
      <article class="rounded-lg border border-line bg-slate-50 p-4">
        <p class="text-xs font-semibold text-brand">{post.data.category}</p>
        <h3 class="mt-2 font-bold leading-snug text-ink">
          <a class="text-ink no-underline hover:text-brand" href={`/${post.slug}/`}>{post.data.title}</a>
        </h3>
        <p class="mt-2 line-clamp-2 text-sm leading-6 text-muted">{getPostExcerpt(post)}</p>
        <a class="mt-3 inline-block text-sm font-semibold" href={`/${post.slug}/`}>继续阅读</a>
      </article>
    ))}
  </div>
</section>

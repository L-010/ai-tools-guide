---
type Props = { name: string; href: string; bestFor: string; note: string };
const { name, href, bestFor, note } = Astro.props;
---
<a href={href} class="block rounded-lg border border-line bg-white p-5 no-underline transition hover:-translate-y-0.5 hover:shadow-sm">
  <h2 class="text-lg font-bold text-ink">{name}</h2>
  <p class="mt-2 text-sm font-semibold text-brand">{bestFor}</p>
  <p class="mt-3 text-sm leading-6 text-muted">{note}</p>
</a>

---
import { shopLink } from "@/utils/urls";
type Props = {
  pageSlug: string;
  text?: string;
  position: string;
  class?: string;
  shopHref?: string;
  shopCategory?: string;
  placement?: string;
  scene?: string;
  variant?: "primary" | "inverse";
};
const {
  pageSlug,
  text = "进入AI工具小店选购",
  position,
  shopHref,
  shopCategory,
  placement = position,
  scene = shopCategory || "article",
  variant = "primary"
} = Astro.props;
const href = shopLink(pageSlug, shopHref, shopCategory);
const variantClass = variant === "inverse"
  ? "border border-white bg-white text-ink shadow-sm hover:bg-slate-100 hover:text-ink"
  : "bg-brand text-white hover:bg-teal-800";
---
<a
  href={href}
  target="_blank"
  rel="nofollow sponsored noopener"
  data-shop-cta
  data-page-slug={pageSlug}
  data-cta-position={position}
  data-placement={placement}
  data-scene={scene}
  class:list={["inline-flex min-h-12 items-center justify-center rounded-md px-5 py-3 text-sm font-semibold no-underline transition", variantClass, Astro.props.class]}
>
  {text}
</a>
